# ── Server (deploy to VPS) ──
PORT=3000
# Optional: admin key to list all connected agents via /api/admin/agents
# ADMIN_KEY=your-admin-secret

# ── Agent (run on your machine) ──
SERVER_URL=wss://claude.pishchykau.eu
# Optional: set a fixed key (auto-generated if not set)
# AGENT_KEY=my-secret-key
# Optional: display name
# AGENT_NAME=My MacBook
